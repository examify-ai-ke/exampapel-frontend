# Exampapel Frontend Environment Variables

# reCAPTCHA Configuration
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here

# API Configuration
NEXT_PUBLIC_API_URL=http://fastapi.localhost/api/v1
NEXT_PUBLIC_API_BASE_URL=http://fastapi.localhost

# Better-Auth Configuration
BETTER_AUTH_SECRET=your-super-secret-key-here-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Application Configuration
NEXT_PUBLIC_APP_NAME=Exampapel
NEXT_PUBLIC_APP_DESCRIPTION=Exam Papers Resource Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development Configuration
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Docker Configuration (if using Docker)
# DOCKER_API_URL=http://backend:8000/api/v1

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Authentication Configuration
NEXT_PUBLIC_AUTH_AUTO_REDIRECT_ON_401=true

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=true
# NEXT_PUBLIC_ENABLE_DARK_MODE=true
# NEXT_PUBLIC_ENABLE_ANALYTICS=false 